APP_ENV=production
APP_BASE_DIR=/srv/app
HTTP_PORT=8080
DATABASE_URL=postgres://fotomagica:fotomagica_change_me@postgres:5432/fotomagica?sslmode=disable
JWT_SECRET=change-me-super-secret
JWT_TTL=24h
ALLOWED_ORIGINS=https://fotomagica.wapainel.com.br
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=/data/storage
GOOGLE_API_KEY=
GOOGLE_ANALYSIS_MODEL=gemini-2.5-flash
GOOGLE_PROMPT_MODEL=gemini-2.5-flash
GOOGLE_IMAGE_MODEL=gemini-2.5-flash-image
WORKER_POLL_INTERVAL=5s
WORKER_MAX_ATTEMPTS=3
GENERATION_RATE_LIMIT_RPM=10
DEFAULT_PLAN_CODE=growth

