{
  "name": "foto-magica-profissional",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web-client": "npm run dev -w apps/web-client",
    "dev:web-admin": "npm run dev -w apps/web-admin",
    "build": "npm run build -w apps/web-client && npm run build -w apps/web-admin",
    "typecheck": "npm run typecheck -w apps/web-client && npm run typecheck -w apps/web-admin"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.9",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}

